"type":"heading","level":2,"text":"Chat States","anchor":"Chat-States"},{"inlineContent":[{"text":"The chat can be in one of the following states, represented by the ","type":"text"},{"code":"ChatState","type":"codeVoice"},{"text":" enum (raw values in parentheses):","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatCreated (1)"},{"type":"text","text":": The chat session has been created but not started."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatStarted (2)"},{"type":"text","text":": The chat session has started."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatPreparing (3)"},{"type":"text","text":": The chat is preparing socket connection."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"chatPrepared (4)"},{"type":"text","text":": The chat has been prepared, configuration fetched and is ready."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatDisconnected (5)"},{"text":": The chat has been disconnected in case of an error.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatReconnecting (6)"},{"text":": The chat is attempting to reconnect.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chatReconnected (7)"},{"text":": The chat has successfully reconnected.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"chatEnding (8)"},{"text":": The chat is in the process of ending.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"chatEnded (9)","type":"codeVoice"},{"text":": The chat session has ended.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"chatClosed (10)"},{"text":": The chat has closed.","type":"text"}],"type":"paragraph"}]},{"content":